import sys
from PyQt6.QtWidgets import (
    QApplication, QMainWindow, QWidget, QVBoxLayout,
    QLabel, QPushButton, QTextEdit, QGroupBox
)
from PyQt6.QtCore import Qt

# -----------------------------
# LAB ENGINE (تعليمي)
# -----------------------------
