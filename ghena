            print(f"\n{Colors.WARNING}🧠 توصيات الذكاء الاصطناعي:{Colors.ENDC}\n{advice}")
        
        # البحث عن suid أو sudo
        if 'sudo' in output:
            print("👀 تحقق من برامج sudo: GTFOBins")
        if '4000' in output:
            print("👀 تحقق من SUID binaries في GTFOBins")
        
        self.session.add_step("privesc_enum", output)
    
    def run(self):
        """تشغيل المنهجية خطوة بخطوة"""
        self.step_recon()
        # بعد الانتهاء من الاستطلاع، قد نكون انتقلنا تلقائياً إلى خطوات أخرى
        # لكن إذا لم يحصل المستخدم على شيل بعد، نسأل إذا أراد متابعة استكشاف خدمات أخرى
        while not self.session.shell_obtained:
            print(f"\n{Colors.BOLD}🧭 القائمة الرئيسية:{Colors.ENDC}")
            print("  1. العودة لتحليل الويب")
            print("  2. تحليل خدمات أخرى (FTP, SSH, ...)")
            print("  3. محاولة استغلال مباشر (searchsploit)")
            print("  4. إنهاء الجلسة وحفظها")
            choice = input(f"{Colors.CYAN}اختر: {Colors.ENDC}").strip()
            if choice == '1':
                self.step_web()
            elif choice == '2':
                self.step_other_services()
            elif choice == '3':
                self.step_exploit_search()
            elif choice == '4':
                break
            else:
                print("اختيار غير صالح.")
        
        # بعد الحصول على شيل، ننتقل لرفع الصلاحيات
        if self.session.shell_obtained:
            self.step_privesc()
        
        print(f"\n{Colors.GREEN}{Colors.BOLD}✅ انتهت الجلسة. شكراً لاستخدامك CTF Coach!{Colors.ENDC}")
    
    def step_exploit_search(self):
        """البحث عن استغلالات باستخدام searchsploit"""
        query = input("🔎 أدخل اسم الخدمة أو الإصدار للبحث: ").strip()
        if query:
            result = search_exploit(query)
            print(result)
        else:
            print("لم يتم إدخال أي شيء.")

