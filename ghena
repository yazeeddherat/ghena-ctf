        if ask_yes_no("هل تريد حفظ الجلسة؟"):
            session.save()
    elif choice == '2':
        filename = input("📁 اسم ملف الجلسة: ").strip()
        try:
            session = Session.load(filename)
            # استعادة حالة الذكاء الاصطناعي
            session.api_key = api_key if api_key else None
            if session.api_key:
                session._init_ai()
            print(f"{Colors.GREEN}✅ تم تحميل الجلسة: {session.target} - {session.platform}{Colors.ENDC}")
            meth = Methodology(session)
            # يمكن إضافة خيار للاستمرار من حيث توقفنا
            meth.run()
        except Exception as e:
            print(f"{Colors.FAIL}خطأ في تحميل الجلسة: {e}{Colors.ENDC}")
    else:
        print("مع السلامة!")
        sys.exit()

if __name__ == "__main__":
    main()
