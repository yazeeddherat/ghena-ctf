# ================= إدارة الجلسات =================
class Session:
    def __init__(self, target: str, platform: str, api_key: str = None):
        self.target = target
        self.platform = platform
        self.api_key = api_key
        self.steps = []          # سجل الخطوات
        self.findings = {}        # النتائج الرئيسية (مثل المنافذ، الخدمات)
        self.shell_obtained = False
        self.ai_enabled = api_key is not None
        self.ai_model = None
        if self.ai_enabled:
            self._init_ai()
    
    def _init_ai(self):
        try:
            genai.configure(api_key=self.api_key)
            self.ai_model = genai.GenerativeModel(
                model_name="gemini-1.5-pro",
                generation_config=GENERATION_CONFIG,
                safety_settings=SAFETY_SETTINGS
            )
            self.ai_chat = self.ai_model.start_chat(history=[])
        except Exception as e:
            print(f"{Colors.FAIL}⚠️ فشل تشغيل الذكاء الاصطناعي: {e}{Colors.ENDC}")
            self.ai_enabled = False
    
    def add_step(self, step_name: str, data: any):
        self.steps.append({
            "time": datetime.datetime.now().isoformat(),
            "step": step_name,
            "data": data
        })
    
    def save(self, filename: str = None):
        if not filename:
            filename = f"session_{self.target.replace('.', '_')}_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        with open(filename, 'w') as f:
            json.dump({
                "target": self.target,
                "platform": self.platform,
                "steps": self.steps,
                "findings": self.findings,
                "shell_obtained": self.shell_obtained
            }, f, indent=2)
        print(f"{Colors.GREEN}💾 تم حفظ الجلسة في {filename}{Colors.ENDC}")
        return filename
    
    @staticmethod
    def load(filename: str):
        with open(filename, 'r') as f:
            data = json.load(f)
        session = Session(data['target'], data['platform'])
        session.steps = data['steps']
        session.findings = data.get('findings', {})
        session.shell_obtained = data.get('shell_obtained', False)
        return session

# ================= أدوات مساعدة =================
def run_command(cmd: str) -> str:
    """تنفيذ أمر وعودة الناتج (مع معالجة الأخطاء)"""
    try:
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=60)
        return result.stdout + result.stderr
    except Exception as e:
        return f"خطأ في تنفيذ الأمر: {e}"

def extract_services_from_nmap(nmap_output: str) -> List[str]:
    """استخراج أسماء الخدمات من مخرجات nmap (تقريبي)"""
    services = set()
    # البحث عن سطور مثل: 80/tcp open  http
    for line in nmap_output.splitlines():
        match = re.search(r'\d+/(tcp|udp)\s+open\s+(\S+)', line)
        if match:
            services.add(match.group(2).lower())
    return list(services)

def search_exploit(service_version: str) -> str:
    """البحث عن استغلال باستخدام searchsploit (إذا كان مثبتاً)"""
    try:
        result = subprocess.run(f"searchsploit {service_version}", shell=True, capture_output=True, text=True)
        return result.stdout
    except:
        return "لم يتم العثور على searchsploit أو حدث خطأ."

def ask_yes_no(question: str) -> bool:
    answer = input(f"{Colors.CYAN}❓ {question} (y/n): {Colors.ENDC}").strip().lower()
    return answer.startswith('y')

def choose_from_list(options: List[str], prompt: str) -> str:
    print(f"{Colors.BLUE}{prompt}{Colors.ENDC}")
    for i, opt in enumerate(options):
        print(f"  {i+1}. {opt}")
    while True:
        choice = input(f"{Colors.CYAN}اختر رقم (أو 0 للتراجع): {Colors.ENDC}").strip()
        if choice.isdigit():
            idx = int(choice) - 1
            if 0 <= idx < len(options):
                return options[idx]
        print(f"{Colors.FAIL}إدخال غير صالح.{Colors.ENDC}")

# ================= خطوات المنهجية =================
class Methodology:
    def __init__(self, session: Session):
        self.session = session
    
    def step_recon(self):
        """المرحلة 1: الاستطلاع - Nmap"""
        print(f"\n{Colors.HEADER}{Colors.BOLD}🔍 المرحلة 1: الاستطلاع (Nmap){Colors.ENDC}")
        
        # خيار تنفيذ nmap تلقائياً أو إدخال النتائج يدوياً
        if ask_yes_no("هل تريد تشغيل Nmap تلقائياً؟ (يحتاج صلاحيات)"):
            cmd = f"nmap -sC -sV {self.session.target}"
            print(f"{Colors.GREEN}تنفيذ: {cmd}{Colors.ENDC}")
            output = run_command(cmd)
            print(output)
        else:
            print(f"{Colors.BLUE}الرجاء لصق مخرجات Nmap (ثم اضغط Enter مرتين للانتهاء):{Colors.ENDC}")
            lines = []
            while True:
                line = sys.stdin.readline().rstrip()
                if line == '':
                    break
                lines.append(line)
            output = "\n".join(lines)
        
        # تحليل النتائج
        services = extract_services_from_nmap(output)
        self.session.findings['services'] = services
        self.session.findings['nmap_raw'] = output
        
        print(f"{Colors.GREEN}✅ الخدمات المكتشفة: {', '.join(services) if services else 'لا شيء'}{Colors.ENDC}")
        
        # استشارة الذكاء الاصطناعي إذا كان مفعلاً
        if self.session.ai_enabled:
            advice = self.get_ai_advice("تحليل nmap", output)
            print(f"\n{Colors.WARNING}🧠 توصيات الذكاء الاصطناعي:{Colors.ENDC}\n{advice}")
        
        self.session.add_step("nmap", output)
        
        # إذا كانت هناك خدمات ويب، انتقل مباشرة إلى خطوة ويب
        if 'http' in services or 'https' in services:
            self.step_web()
        else:
            self.step_other_services()
    
    def get_ai_advice(self, context: str, data: str) -> str:
        """إرسال البيانات إلى الذكاء الاصطناعي للحصول على نصائح استراتيجية"""
        if not self.session.ai_enabled:
            return "الذكاء الاصطناعي غير مفعّل."
        
        prompt = f"""
[الدور: قائد فريق الاختراق الأحمر]
[الهدف: {self.session.target}]
[السياق: {context}]

البيانات المدخلة:
{data}

المطلوب:
1. تحليل فني دقيق للنتائج.
2. تحديد نقاط الضعف المحتملة (CVEs، تكوينات خاطئة).
3. اقتراح الخطوات التالية بأوامر محددة.
4. تنبيهات أمنية إن لزم الأمر.

الرجاء الرد بتنسيق منظم مع عناوين واضحة.
"""
        try:
            response = self.session.ai_chat.send_message(prompt)
            return response.text
        except Exception as e:
            return f"حدث خطأ في الاتصال بالذكاء الاصطناعي: {e}"
    
    def step_web(self):
        """المرحلة 2: تحليل خدمات الويب"""
        print(f"\n{Colors.HEADER}{Colors.BOLD}🌐 المرحلة 2: تحليل الويب{Colors.ENDC}")
        
        # فتح المتصفح (اختياري)
        if ask_yes_no("هل تريد فتح المتصفح على الهدف؟"):
