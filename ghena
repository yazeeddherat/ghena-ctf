
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Web Security Scanner</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Cairo:wght@400;600;700&display=swap');

  :root {
    --bg: #0a0d14;
    --bg2: #111520;
    --bg3: #181d2e;
    --border: #1e2540;
    --accent: #00d4ff;
    --accent2: #0099cc;
    --red: #ff4444;
    --orange: #ff8800;
    --green: #00cc66;
    --text: #e0e8ff;
    --text2: #7a8ab0;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'Cairo', sans-serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
  }

  /* grid bg */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  header {
    position: relative;
    z-index: 1;
    padding: 32px 40px 28px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .shield {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }

  header h1 {
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 1px;
  }

  header p {
    font-size: 13px;
    color: var(--text2);
    margin-top: 2px;
    font-family: var(--mono);
  }

  .tag {
    margin-right: auto;
    margin-left: 0;
    background: rgba(0,212,255,0.08);
    border: 1px solid rgba(0,212,255,0.2);
    color: var(--accent);
    font-size: 11px;
    font-family: var(--mono);
    padding: 4px 10px;
    border-radius: 4px;
  }

  main {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 40px auto;
    padding: 0 24px;
  }

  .scan-box {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 36px;
    margin-bottom: 28px;
  }

  .scan-box label {
    display: block;
    font-size: 13px;
    font-family: var(--mono);
    color: var(--accent);
    margin-bottom: 10px;
    letter-spacing: 1px;
  }

  .input-row {
    display: flex;
    gap: 10px;
  }

  .input-row input {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 13px 16px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    direction: ltr;
    outline: none;
    transition: border-color 0.2s;
  }

  .input-row input:focus { border-color: var(--accent); }
  .input-row input::placeholder { color: var(--text2); }

  #scanBtn {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 8px;
    padding: 13px 28px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  #scanBtn:hover { background: #00eeff; transform: translateY(-1px); }
  #scanBtn:disabled { background: #1e2540; color: var(--text2); cursor: not-allowed; transform: none; }

  .warning {
    margin-top: 12px;
    font-size: 12px;
    color: var(--orange);
    font-family: var(--mono);
  }

  /* Loading */
  #loadingBox {
    display: none;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 36px;
    margin-bottom: 28px;
    text-align: center;
  }

  .spinner-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .spinner {
    width: 24px; height: 24px;
    border: 2px solid var(--border);
    border-top: 2px solid var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .scanning-text {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--accent);
  }

  .steps-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }

  .step {
    font-family: var(--mono);
    font-size: 12px;
    padding: 5px 14px;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--text2);
    transition: all 0.3s;
  }

  .step.active { border-color: var(--accent); color: var(--accent); background: rgba(0,212,255,0.07); }
  .step.done { border-color: var(--green); color: var(--green); background: rgba(0,204,102,0.07); }

  /* Summary cards */
  .cards-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0,1fr));
    gap: 12px;
    margin-bottom: 24px;
  }

  @media(max-width:580px) { .cards-row { grid-template-columns: repeat(2,1fr); } }

  .card {
    border-radius: 12px;
    padding: 20px 16px;
    text-align: center;
    border: 1px solid transparent;
  }

  .card-num { font-size: 32px; font-weight: 700; font-family: var(--mono); }
  .card-lbl { font-size: 12px; margin-top: 4px; font-family: var(--mono); }

  .card-total  { background: rgba(0,212,255,0.08); border-color: rgba(0,212,255,0.2); }
  .card-total  .card-num { color: var(--accent); }
  .card-total  .card-lbl { color: var(--accent2); }

  .card-high   { background: rgba(255,68,68,0.08); border-color: rgba(255,68,68,0.2); }
  .card-high   .card-num { color: var(--red); }
  .card-high   .card-lbl { color: #cc3333; }

  .card-medium { background: rgba(255,136,0,0.08); border-color: rgba(255,136,0,0.2); }
  .card-medium .card-num { color: var(--orange); }
  .card-medium .card-lbl { color: #cc7700; }

  .card-low    { background: rgba(0,204,102,0.08); border-color: rgba(0,204,102,0.2); }
  .card-low    .card-num { color: var(--green); }
  .card-low    .card-lbl { color: #009944; }

  /* Sections */
  .section {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 20px;
  }

  .section-title {
    font-size: 13px;
    font-family: var(--mono);
    color: var(--accent);
    letter-spacing: 1px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Info items */
  .info-item {
    display: flex;
    gap: 12px;
    padding: 9px 12px;
    background: var(--bg);
    border-radius: 6px;
    margin-bottom: 6px;
    border: 1px solid var(--border);
  }

  .info-key {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent2);
    min-width: 140px;
  }

  .info-val {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text);
    direction: ltr;
    word-break: break-all;
  }

  /* Vuln cards */
  .vuln-card {
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 12px;
    border: 1px solid var(--border);
  }

  .vuln-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
  }

  .vuln-head-title {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
  }

  .badge {
    font-family: var(--mono);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .vuln-high .vuln-head { background: rgba(255,68,68,0.12); border-bottom: 1px solid rgba(255,68,68,0.2); }
  .vuln-high .vuln-head-title { color: var(--red); }
  .vuln-high .badge { background: rgba(255,68,68,0.15); color: var(--red); }

  .vuln-medium .vuln-head { background: rgba(255,136,0,0.12); border-bottom: 1px solid rgba(255,136,0,0.2); }
  .vuln-medium .vuln-head-title { color: var(--orange); }
  .vuln-medium .badge { background: rgba(255,136,0,0.15); color: var(--orange); }

  .vuln-low .vuln-head { background: rgba(0,204,102,0.12); border-bottom: 1px solid rgba(0,204,102,0.2); }
  .vuln-low .vuln-head-title { color: var(--green); }
  .vuln-low .badge { background: rgba(0,204,102,0.15); color: var(--green); }

  .vuln-body {
    padding: 14px 16px;
    background: var(--bg);
  }

  .vuln-row {
    display: flex;
    gap: 10px;
    margin-bottom: 8px;
    font-size: 13px;
  }

  .vuln-row:last-child { margin-bottom: 0; }

  .vuln-lbl {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text2);
    min-width: 80px;
    padding-top: 2px;
  }

  .vuln-val { color: var(--text); line-height: 1.6; }

  /* Download btn */
  .dl-wrap { text-align: center; padding: 10px 0 20px; }

  .dl-btn {
    background: transparent;
    border: 1px solid var(--green);
    color: var(--green);
    padding: 12px 36px;
    border-radius: 8px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--mono);
  }

  .dl-btn:hover { background: rgba(0,204,102,0.1); transform: translateY(-1px); }

  /* Error */
  .error-box {
    display: none;
    background: rgba(255,68,68,0.08);
    border: 1px solid rgba(255,68,68,0.3);
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 20px;
    font-family: var(--mono);
    font-size: 13px;
    color: var(--red);
  }

  .no-vulns {
    text-align: center;
    padding: 24px;
    color: var(--green);
    font-family: var(--mono);
    font-size: 14px;
  }

  footer {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 24px;
    color: var(--text2);
    font-family: var(--mono);
    font-size: 11px;
    border-top: 1px solid var(--border);
    margin-top: 20px;
  }
</style>
</head>
<body>

<header>
  <div class="shield">🛡️</div>
  <div>
    <h1>WEB SECURITY SCANNER</h1>
    <p>Vulnerability Detection & Reporting System</p>
  </div>
  <div class="tag">v1.0 — DEMO</div>
</header>

<main>

  <div class="scan-box">
    <label>// TARGET URL</label>
    <div class="input-row">
      <input type="text" id="urlInput" placeholder="https://example.com" autocomplete="off" />
      <button id="scanBtn" onclick="startScan()">▶ ابدأ الفحص</button>
    </div>
    <div class="warning">⚠ استخدم هذه الأداة فقط على مواقع تملكها أو لديك إذن صريح بفحصها</div>
  </div>

  <div id="loadingBox">
    <div class="spinner-wrap">
      <div class="spinner"></div>
      <span class="scanning-text" id="scanningLabel">SCANNING...</span>
    </div>
    <div class="steps-grid">
      <span class="step" id="s1">SSL/TLS</span>
      <span class="step" id="s2">SEC HEADERS</span>
      <span class="step" id="s3">SQL INJECTION</span>
      <span class="step" id="s4">XSS</span>
      <span class="step" id="s5">SENSITIVE FILES</span>
      <span class="step" id="s6">DNS</span>
    </div>
  </div>

  <div class="error-box" id="errorBox"></div>

  <div id="resultsBox" style="display:none;">
    <div class="cards-row">
      <div class="card card-total"><div class="card-num" id="cTotal">0</div><div class="card-lbl">TOTAL</div></div>
      <div class="card card-high"><div class="card-num" id="cHigh">0</div><div class="card-lbl">HIGH</div></div>
      <div class="card card-medium"><div class="card-num" id="cMed">0</div><div class="card-lbl">MEDIUM</div></div>
      <div class="card card-low"><div class="card-num" id="cLow">0</div><div class="card-lbl">LOW</div></div>
    </div>

    <div class="section">
      <div class="section-title">◈ SCAN INFO</div>
      <div id="infoList"></div>
    </div>

    <div class="section">
      <div class="section-title">◈ VULNERABILITIES</div>
      <div id="vulnList"></div>
    </div>

    <div class="dl-wrap">
      <button class="dl-btn" onclick="downloadReport()">⬇ تحميل التقرير TXT</button>
    </div>
  </div>

</main>

<footer>WEB SECURITY SCANNER — FOR AUTHORIZED USE ONLY — © 2025</footer>

<script>
// =====================
// بيانات الفحص الوهمية (Demo)
// =====================
// ملاحظة: هذا demo يعمل في المتصفح مباشرة
// للفحص الحقيقي شغّل app.py على جهازك

const DEMO_VULNS = {
  ssl: {
    missing: { type:'Missing HTTPS', severity:'high', description:'الموقع لا يستخدم HTTPS — البيانات تنتقل بدون تشفير', recommendation:'استخدم شهادة SSL وحوّل كل الطلبات من HTTP إلى HTTPS' },
    expiring: { type:'SSL Certificate Expiring', severity:'medium', description:'شهادة SSL ستنتهي خلال 15 يوم', recommendation:'جدد شهادة SSL قبل انتهائها' }
  },
  headers: [
    { type:'Missing Header: X-Frame-Options', severity:'medium', description:'الموقع عرضة لهجمات Clickjacking', recommendation:'أضف: X-Frame-Options: DENY' },
    { type:'Missing Header: Strict-Transport-Security', severity:'high', description:'لا يوجد HSTS — يمكن تحويل الاتصال لـ HTTP', recommendation:'أضف: Strict-Transport-Security: max-age=31536000' },
    { type:'Missing Header: Content-Security-Policy', severity:'high', description:'لا يوجد CSP — الموقع عرضة لهجمات XSS المتقدمة', recommendation:'أضف Content-Security-Policy مناسب لموقعك' },
    { type:'Server Version Disclosure', severity:'low', description:'الـ Server يكشف إصداره: Apache/2.4.51', recommendation:'أخفِ معلومات الـ Server من الهيدرز' }
  ],
  sql: { type:'SQL Injection', severity:'high', description:'تم اكتشاف ثغرة SQL Injection في نموذج تسجيل الدخول', recommendation:'استخدم Prepared Statements وتحقق من كل المدخلات' },
  xss: { type:'XSS — Cross Site Scripting', severity:'high', description:'تم اكتشاف ثغرة XSS في حقل البحث', recommendation:'شفّر كل المدخلات قبل عرضها وفعّل CSP' },
  files: [
    { type:'Sensitive File Exposed', severity:'high', description:'ملف حساس مكشوف: /.env', recommendation:'احذف أو احمِ الوصول لملفات البيئة' },
    { type:'Sensitive File Exposed', severity:'high', description:'ملف حساس مكشوف: /wp-config.php', recommendation:'انقل ملف الإعدادات خارج مجلد الويب' }
  ],
  dns: { type:'Missing SPF Record', severity:'medium', description:'لا يوجد SPF Record — الموقع عرضة لانتحال البريد', recommendation:'أضف SPF Record في إعدادات DNS' }
};

let scanReport = null;
let stepTimer = null;

async function startScan() {
  const url = document.getElementById('urlInput').value.trim();
  if (!url) { showError('الرجاء إدخال رابط الموقع'); return; }

  document.getElementById('resultsBox').style.display = 'none';
  document.getElementById('errorBox').style.display = 'none';
  document.getElementById('loadingBox').style.display = 'block';
  document.getElementById('scanBtn').disabled = true;
  document.getElementById('scanBtn').textContent = '⏳ جاري الفحص...';

  resetSteps();
  await animateSteps();
  await runDemoScan(url);

  document.getElementById('loadingBox').style.display = 'none';
  document.getElementById('scanBtn').disabled = false;
  document.getElementById('scanBtn').textContent = '▶ ابدأ الفحص';
}

function resetSteps() {
  for (let i = 1; i <= 6; i++) {
    const el = document.getElementById('s'+i);
    el.className = 'step';
  }
}

async function animateSteps() {
  const stepNames = ['SSL/TLS','SEC HEADERS','SQL INJECTION','XSS','SENSITIVE FILES','DNS'];
  for (let i = 1; i <= 6; i++) {
    document.getElementById('s'+i).className = 'step active';
    document.getElementById('scanningLabel').textContent = 'SCANNING ' + stepNames[i-1] + '...';
    await sleep(900);
    document.getElementById('s'+i).className = 'step done';
    document.getElementById('s'+i).textContent = '✓ ' + stepNames[i-1];
  }
  document.getElementById('scanningLabel').textContent = 'SCAN COMPLETE';
}

async function runDemoScan(url) {
  const now = new Date().toLocaleString('ar-EG');
  const isHttp = url.startsWith('http://');
  const domain = url.replace(/https?:\/\//,'').split('/')[0];

  const vulns = [];
  const info = [
    { title:'Target URL', value: url },
    { title:'Domain', value: domain },
    { title:'Scan Date', value: now },
    { title:'IP Address', value: '104.21.' + Math.floor(Math.random()*255) + '.' + Math.floor(Math.random()*255) },
    { title:'Server', value: 'Apache/2.4.51 (Unix)' },
    { title:'SSL Certificate', value: isHttp ? 'غير متوفر' : 'ينتهي بعد 15 يوم' }
  ];

  if (isHttp) vulns.push({...DEMO_VULNS.ssl.missing, timestamp: now});
  else vulns.push({...DEMO_VULNS.ssl.expiring, timestamp: now});

  DEMO_VULNS.headers.forEach(h => vulns.push({...h, timestamp: now}));
  vulns.push({...DEMO_VULNS.sql, timestamp: now});
  vulns.push({...DEMO_VULNS.xss, timestamp: now});
  DEMO_VULNS.files.forEach(f => vulns.push({...f, timestamp: now}));
  vulns.push({...DEMO_VULNS.dns, timestamp: now});

  const summary = {
    total: vulns.length,
    high: vulns.filter(v=>v.severity==='high').length,
    medium: vulns.filter(v=>v.severity==='medium').length,
    low: vulns.filter(v=>v.severity==='low').length
  };

  scanReport = { url, domain, date: now, vulns, info, summary };
  showResults(scanReport);
}

function showResults(r) {
  document.getElementById('cTotal').textContent = r.summary.total;
  document.getElementById('cHigh').textContent  = r.summary.high;
  document.getElementById('cMed').textContent   = r.summary.medium;
  document.getElementById('cLow').textContent   = r.summary.low;

  const infoList = document.getElementById('infoList');
  infoList.innerHTML = '';
  r.info.forEach(item => {
    infoList.innerHTML += `
      <div class="info-item">
        <span class="info-key">${item.title}</span>
        <span class="info-val">${item.value}</span>
      </div>`;
  });

  const vulnList = document.getElementById('vulnList');
  vulnList.innerHTML = '';

  if (!r.vulns.length) {
    vulnList.innerHTML = '<div class="no-vulns">✓ لم يتم اكتشاف ثغرات</div>';
  } else {
    const order = {high:0, medium:1, low:2};
    const sorted = [...r.vulns].sort((a,b)=>order[a.severity]-order[b.severity]);
    const sevLabel = {high:'HIGH ●', medium:'MEDIUM ●', low:'LOW ●'};
    sorted.forEach((v,i) => {
      vulnList.innerHTML += `
        <div class="vuln-card vuln-${v.severity}">
          <div class="vuln-head">
            <span class="vuln-head-title">#${i+1} ${v.type}</span>
            <span class="badge">${sevLabel[v.severity]}</span>
          </div>
          <div class="vuln-body">
            <div class="vuln-row"><span class="vuln-lbl">DESCRIPTION</span><span class="vuln-val">${v.description}</span></div>
            <div class="vuln-row"><span class="vuln-lbl">FIX</span><span class="vuln-val">${v.recommendation}</span></div>
            <div class="vuln-row"><span class="vuln-lbl">TIME</span><span class="vuln-val" style="font-family:var(--mono);font-size:11px;">${v.timestamp}</span></div>
          </div>
        </div>`;
    });
  }

  document.getElementById('resultsBox').style.display = 'block';
  document.getElementById('resultsBox').scrollIntoView({behavior:'smooth'});
}

function downloadReport() {
  if (!scanReport) return;
  const r = scanReport;
  let txt = `=================================================\n`;
  txt += `  WEB SECURITY SCANNER — SCAN REPORT\n`;
  txt += `=================================================\n\n`;
  txt += `TARGET : ${r.url}\n`;
  txt += `DOMAIN : ${r.domain}\n`;
  txt += `DATE   : ${r.date}\n\n`;
  txt += `-------------------------------------------------\n`;
  txt += `SUMMARY\n`;
  txt += `-------------------------------------------------\n`;
  txt += `Total Vulnerabilities : ${r.summary.total}\n`;
  txt += `High                  : ${r.summary.high}\n`;
  txt += `Medium                : ${r.summary.medium}\n`;
  txt += `Low                   : ${r.summary.low}\n\n`;
  txt += `-------------------------------------------------\n`;
  txt += `SYSTEM INFO\n`;
  txt += `-------------------------------------------------\n`;
  r.info.forEach(i => { txt += `${i.title.padEnd(20)}: ${i.value}\n`; });
  txt += `\n-------------------------------------------------\n`;
  txt += `VULNERABILITIES FOUND\n`;
  txt += `-------------------------------------------------\n\n`;
  const order = {high:0,medium:1,low:2};
  const sorted = [...r.vulns].sort((a,b)=>order[a.severity]-order[b.severity]);
  sorted.forEach((v,i) => {
    txt += `[${v.severity.toUpperCase()}] #${i+1} ${v.type}\n`;
    txt += `Description   : ${v.description}\n`;
    txt += `Recommendation: ${v.recommendation}\n`;
    txt += `Time          : ${v.timestamp}\n\n`;
  });
  txt += `=================================================\n`;
  txt += `Generated by Web Security Scanner v1.0\n`;
  txt += `FOR AUTHORIZED USE ONLY\n`;
  txt += `=================================================\n`;

  const blob = new Blob([txt], {type:'text/plain;charset=utf-8'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `scan_report_${r.domain}_${Date.now()}.txt`;
  a.click();
}

function showError(msg) {
  const el = document.getElementById('errorBox');
  el.textContent = '✗ ' + msg;
  el.style.display = 'block';
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

document.getElementById('urlInput').addEventListener('keypress', e => {
  if (e.key === 'Enter') startScan();
});
</script>
</body>
</html>
