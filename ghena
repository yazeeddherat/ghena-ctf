        # جمع معلومات عن النظام
        print("📋 أوامر مفيدة لجمع المعلومات:")
        commands = [
            "whoami",
            "id",
            "uname -a",
            "sudo -l",
            "find / -perm -4000 2>/dev/null",
            "cat /etc/passwd",
            "ps aux",
            "netstat -tulpn",
            "crontab -l",
            "ls -la /home/",
