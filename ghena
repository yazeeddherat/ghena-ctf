        self.step_web_general()  # العودة للخطوات العامة
    
    def step_login(self):
        print(f"\n{Colors.HEADER}{Colors.BOLD}🔐 مرحلة تحليل تسجيل الدخول{Colors.ENDC}")
        # اقتراح هجمات
        print("💡 أفكار للاختبار:")
