    def next_stage(self):
        if self.stage < len(self.stages):
            data = self.stages[self.stage]
            self.stage += 1
            return data
        return None


# -----------------------------
# GUI
# -----------------------------
class GhenaCTFAcademy(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("GHENA CTF ACADEMY")
        self.setMinimumSize(900, 600)
        self.engine = LabEngine()
        self.init_ui()

    def init_ui(self):
        main = QWidget()
        layout = QVBoxLayout()

        title = QLabel("🎓 GHENA CTF ACADEMY\nBeginner Training Lab")
        title.setAlignment(Qt.AlignmentFlag.AlignCenter)
        title.setStyleSheet("font-size: 22px; font-weight: bold;")

        self.stage_box = QGroupBox("Stage Explanation")
        stage_layout = QVBoxLayout()
        self.lesson_area = QTextEdit()
        self.lesson_area.setReadOnly(True)
        stage_layout.addWidget(self.lesson_area)
        self.stage_box.setLayout(stage_layout)

        self.result_box = QGroupBox("Lab Result")
        result_layout = QVBoxLayout()
        self.result_area = QTextEdit()
        self.result_area.setReadOnly(True)
        result_layout.addWidget(self.result_area)
        self.result_box.setLayout(result_layout)

        self.btn_next = QPushButton("▶ Next Step")
        self.btn_next.setStyleSheet("font-size: 16px; padding: 10px;")
        self.btn_next.clicked.connect(self.next_step)

        layout.addWidget(title)
        layout.addWidget(self.stage_box)
        layout.addWidget(self.result_box)
        layout.addWidget(self.btn_next)

        main.setLayout(layout)
        self.setCentralWidget(main)

        self.next_step()

    def next_step(self):
        data = self.engine.next_stage()
        if not data:
            self.lesson_area.setText("🎉 LAB COMPLETED!\nYou are ready for the next lab.")
            self.result_area.clear()
            self.btn_next.setEnabled(False)
            return

        self.stage_box.setTitle(data["title"])
        self.lesson_area.setText(data["lesson"])
        self.result_area.setText(data["result"])


# -----------------------------
# RUN
# -----------------------------
if __name__ == "__main__":
    app = QApplication(sys.argv)
    win = GhenaCTFAcademy()
    win.show()
    sys.exit(app.exec())
