        # خطوة تعداد الدلائل
        if ask_yes_no("هل تريد تشغيل Gobuster لاكتشاف الدلائل؟"):
            wordlist = input("👣 مسار قائمة الكلمات (افتراضي: /usr/share/wordlists/dirb/common.txt): ").strip()
            if not wordlist:
                wordlist = "/usr/share/wordlists/dirb/common.txt"
            cmd = f"gobuster dir -u http://{self.session.target} -w {wordlist}"
            print(f"{Colors.GREEN}تنفيذ: {cmd}{Colors.ENDC}")
            output = run_command(cmd)
            print(output)
            
            # استخراج الدلائل
            dirs = re.findall(r'/(\w+)/?\s+\(Status: 200\)', output)
            if dirs:
                print(f"{Colors.GREEN}✅ الدلائل المكتشفة: {', '.join(dirs)}{Colors.ENDC}")
                self.session.findings['web_dirs'] = dirs
            else:
                print(f"{Colors.WARNING}⚠️ لم يتم العثور على دلائل.{Colors.ENDC}")
        else:
            output = None
        
        # تحليل الذكاء الاصطناعي
        if self.session.ai_enabled:
            data_to_send = f"ملاحظات: {observations}\n"
            if output:
                data_to_send += f"مخرجات Gobuster:\n{output}"
            advice = self.get_ai_advice("تحليل الويب", data_to_send)
            print(f"\n{Colors.WARNING}🧠 توصيات الذكاء الاصطناعي:{Colors.ENDC}\n{advice}")
        
        self.session.add_step("web_analysis", {"observations": observations, "gobuster": output})
        
        # التوجيه بناءً على وجود رفع ملفات أو تسجيل دخول
        if 'upload' in observations or (output and 'upload' in output):
            self.step_upload()
        elif 'login' in observations or (self.session.findings.get('web_dirs') and 'admin' in self.session.findings['web_dirs']):
            self.step_login()
        else:
            self.step_web_general()
    
